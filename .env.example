# Supabase Configuración
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-de-supabase

# ============================================================
-- SETUP DESDE CERO CON SUPABASE
-- ============================================================
-- 1. Crea un proyecto gratuito en Supabase (servidor en São Paulo recomendado).
-- 2. Ve al "SQL Editor" y ejecuta el contenido del archivo `supabase/schema.sql`.
-- 3. Ve a Settings -> API y copia la "Project URL" y la anon "public" key.
-- 4. Pégalas aquí arriba y en tu archivo `.env`.
-- 5. Ejecuta la app localmente con `pnpm dev`.
-- 6. En el primer inicio serás redirigido a `/setup` para crear la cuenta Super Admin.
